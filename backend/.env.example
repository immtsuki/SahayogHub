# Copy this to .env and fill in your values
SECRET_KEY=your-very-secret-django-key-here
DEBUG=True

# Neon PostgreSQL (or any PostgreSQL DATABASE_URL)
# Get this from your Neon dashboard: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# JWT token lifetimes (in minutes / days)
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# AI services
# image_comparision: uvicorn api:app --host 0.0.0.0 --port 8011
# blur_ai_for_documentation: uvicorn server_yolo_fastapi:app --host 0.0.0.0 --port 8012
AI_COMPARISON_URL=http://127.0.0.1:8011/api/compare-candidates
AI_REDACTION_URL=http://127.0.0.1:8012/redact-image
AI_MATCH_THRESHOLD=62
AI_VISUAL_MATCH_THRESHOLD=55
AI_REDACTION_TIMEOUT_SECONDS=10
AI_COMPARISON_TIMEOUT_SECONDS=8
AI_SERVICE_HEALTH_TIMEOUT_SECONDS=1
